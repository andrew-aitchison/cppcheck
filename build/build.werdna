#!/bin/bash

module load use.own
module remove gcc
module load llvm

cd /home/werdna/src/cppcheck/cppcheck
mkdir -p build
cd build

export FILESDIR=/usr/local/share/Cppcheck

cmake -DUSE_QT6=ON -DBUILD_GUI=ON -DHAVE_RULES=ON ..
# -DUSE_MATCHCOMPILER=ON

cmake --build . -v

make -j$(nproc) -l$(($(nproc)-1)) install

